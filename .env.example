# Example environment variables for local development.
# Copy this file to `.env` and fill in real values (do NOT commit `.env`).

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://<DB_USER>:<DB_PASS>@<YOUR_HOST>/<DB_NAME>

# JWT
JWT_ACCESS_SECRET=<your_jwt_access_secret>
JWT_REFRESH_SECRET=<your_jwt_refresh_secret>
JWT_ACCESS_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=30d

# Verification email (Brevo)
BREVO_API_KEY=<brevo_api_key>
BREVO_SENDER_EMAIL=you@example.com
BREVO_SENDER_NAME=Payment Notify

# Public API root for links in emails
API_PUBLIC_URL=https://your-deployed-api.example.com/api
APP_NAME=Payment Notify

# Frontend URLs
FRONTEND_URL=https://your-frontend.example.com/app
ADMIN_URL=https://your-frontend.example.com/admin

# Keep-alive URL (optional)
KEEP_ALIVE_URL=https://your-deployed-api.example.com/health

# Support contact
SUPPORT_WHATSAPP_NUMBER=+10000000000

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<cloudinary_api_key>
CLOUDINARY_API_SECRET=<cloudinary_api_secret>

# NOTE: Never commit real secrets to source control. Use a secrets manager or
# CI/CD encrypted variables for production deployments.
# Server
NODE_ENV=development
PORT=5000

# MongoDB — if password contains $ or other special chars, wrap the whole URI in double quotes:
# MONGODB_URI="mongodb+srv://user:pass$word@cluster/db?opts"

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
# ~30 days: users stay signed in about a month before password login again (shorten for stricter security)
JWT_ACCESS_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=30d

# Verification email — Brevo (https://www.brevo.com) Transactional API
# Create API key: Brevo dashboard → SMTP & API → API keys
BREVO_API_KEY=
# Legacy alias (same as BREVO_API_KEY)
# SENDINBLUE_API_KEY=
# Must be a verified sender in Brevo (Senders → Domains or single sender)
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Your App
# Or one line: BREVO_FROM="Your App <noreply@yourdomain.com>" (optional if BREVO_SENDER_EMAIL is set)

# Public API root (include /api) — used in verification links in emails
API_PUBLIC_URL=http://localhost:5000/api
APP_NAME=Your App

# GET /api/health/email — brevoReady

# Frontend — site origin only (no /app). App links add /app/verify-email themselves.
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# Keep-alive (Render)
KEEP_ALIVE_URL=

# Shown on user Support screen (optional). E.g. +966501234567 — https://wa.me/966501234567
SUPPORT_WHATSAPP_NUMBER=

# Cloudinary — subscription payment proof images (mobile app upload)
# Easiest: one line from Cloudinary dashboard (API Environment variable)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set all three:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional folder prefix (default subscription-proofs)
# CLOUDINARY_SUBSCRIPTION_FOLDER=subscription-proofs

# Payment proof images: resize + JPEG before upload (sharp). Optional overrides:
# PAYMENT_PROOF_MAX_WIDTH=1920
# PAYMENT_PROOF_JPEG_QUALITY=82
